# Google Gemini API key — required for live AI generation.
# Get one (free) at https://aistudio.google.com/apikey
# Without it the app automatically falls back to the offline rule-based engine.
GEMINI_API_KEY=AIza...

# Model to use (defaults to gemini-2.0-flash if unset).
GEMINI_MODEL=gemini-2.0-flash

# Optional: max generations allowed per IP per hour (default 30). Set 0 to disable.
RATE_LIMIT_PER_HOUR=30
