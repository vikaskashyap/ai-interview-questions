# Anthropic API key — required for live AI generation.
# Without it the app automatically falls back to the offline rule-based engine.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Model to use (defaults to claude-sonnet-4-6 if unset).
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: max generations allowed per IP per hour (default 30). Set 0 to disable.
RATE_LIMIT_PER_HOUR=30
